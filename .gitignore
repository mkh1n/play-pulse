# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Icon?
iTunes_Control/
@__thumb
