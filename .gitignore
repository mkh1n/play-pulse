```gitignore
# Dependencies
node_modules/
.pnpm-store/
.npm/
.yarn/

# Build outputs
dist/
build/
coverage/
.eslintcache

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated
.DS_Store
Thumbs.db

# Logs
*.log

# TypeScript/JavaScript specific
*.tsbuildinfo
.next/
.nuxt/
public/
```